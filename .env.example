# Capaldi Training — environment variables
# Copy this file to .env and fill in the real values when available.
# Anything prefixed with PUBLIC_ is exposed to the client-side bundle.

# Formspree endpoint for the contact form.
# Create one at https://formspree.io (free tier is fine for launch).
PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id

# Cal.com booking link for the free 15-min consultation.
# e.g. https://cal.com/andy-capaldi/consultation
PUBLIC_CAL_COM_URL=https://cal.com/your-handle/consultation

# Real phone number for the contact page.
# Client-side only — obfuscated on the server, assembled in the browser.
PUBLIC_PHONE_NUMBER=555-555-5555

# Contact email shown on the Contact page.
PUBLIC_CONTACT_EMAIL=andy@capalditraining.com

# Sanity CMS (populate during Phase 4).
SANITY_PROJECT_ID=
SANITY_DATASET=production
